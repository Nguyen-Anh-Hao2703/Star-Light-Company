@page
@model Star_Light_Company.Pages.unityModel
@{
    ViewData["Title"] = "Trang Gói Unity của Star Light Company";
}
<div>
    @foreach(var asset in Model.assets)
    {
        <div class="col-12 mb-3">
            <div class="card exam-card border-0 shadow-sm">
                <div class="card-body d-flex align-items-center justify-content-between p-3">
                    <div class="d-flex align-items-center flex-grow-1">
                        <img src="~/Unity/Unity.png" class="img-fluid mb-3" style="max-height: 30px;" />
                        <div class="overflow-hidden">
                            <span class="fw-bold d-block text-truncate" style="max-width: 400px;">@asset</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <a href="@Model.GetFileUrl(asset)" target="_blank" download="@asset"
                           class="btn btn-outline-success btn-sm fw-bold">📥 Tải về</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
