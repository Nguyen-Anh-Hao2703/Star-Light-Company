@page
@model IndexModel
@{
    ViewData["Title"] = "Star Light Company - Kiến tạo thế giới kỹ thuật số";
}

<div class="hero-section text-center py-5 mb-5">
    <div class="container py-5">
        <h1 class="display-3 fw-bold text-dark">Star Light <span class="text-success">Company</span></h1>
        <p class="lead fs-4 text-muted mb-4">Công ty về công nghệ giáo dục và giải pháp số sáng tạo.</p>
        <a href="#products" class="btn btn-success btn-lg px-5 py-3 shadow-sm fw-bold">Khám phá sản phẩm</a>
    </div>
</div>

<div class="container" id="products">
    <div class="row align-items-center mb-5 pb-5">
        <div class="col-md-7">
            <div class="p-4 bg-white shadow-sm rounded-4 border-top border-success border-5">
                <img src="~/learning.png" class="img-fluid mb-3" style="max-height: 50px;" />
                <h2 class="fw-bold">Hệ thống Learning</h2>
                <p class="text-muted">Nền tảng quản lý bài tập và tài liệu thông minh dành cho giáo dục hiện đại.</p>
                <ul class="list-unstyled mb-4">
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i> Làm bài tập trực tuyến định dạng .qs</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i> Quản lý lớp học thông minh</li>
                </ul>
                <a href="https://learning-vn.onrender.com/" target="_blank" class="btn btn-outline-success px-4 fw-bold">Trải nghiệm ngay</a>
            </div>
        </div>
        <div class="col-md-5 text-center">
            <a href="https://learning-vn.onrender.com/" target="_blank" class="d-inline-block img-hover mt-4 mt-md-0">
                <img src="~/learning.png" class="img-fluid rounded-4 shadow-lg border" style="max-width: 220px;" />
            </a>
        </div>
    </div>

    <div class="row align-items-center mb-5">
        <div class="col-md-5 text-center order-2 order-md-1">
            <a href="https://csharpvn-community.onrender.com" target="_blank" class="d-inline-block img-hover mt-4 mt-md-0">
                <img src="~/csharp vietnamese.png" class="img-fluid rounded-4 shadow-lg border" style="max-width: 220px;" />
            </a>
        </div>
        <div class="col-md-7 order-1 order-md-2">
            <div class="p-4 bg-white shadow-sm rounded-4 border-top border-success border-5">
                <img src="~/csharp vietnamese.png" class="img-fluid mb-3" style="max-height: 50px;" />
                <h2 class="fw-bold">CSharp Vietnamese Studio</h2>
                <p class="text-muted">Ứng dụng lập trình sử dụng tiếng Việt hoàn toàn mới cho người Việt.</p>
                <ul class="list-unstyled mb-4">
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i> Định dạng dự án .csvn và .csvnproj</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i> Từ điển lập trình tiếng Việt tích hợp</li>
                </ul>
                <a href="https://csharpvn-community.onrender.com" target="_blank" class="btn btn-outline-success px-4 fw-bold">Trải nghiệm ngay</a>
            </div>
        </div>
    </div>
    <div class="row align-items-center mb-5 pb-5">
        <div class="col-md-7">
            <div class="p-4 bg-white shadow-sm rounded-4 border-top border-success border-5">
                <img src="~/Unity/Unity.png" class="img-fluid mb-3" style="max-height: 50px;" />
                <h2 class="fw-bold">Gói Unity</h2>
                <p class="text-muted">Một số gói giúp trang trí dự án Unity của bạn</p>
                <a href = "/unity" target="_blank" class="btn btn-outline-success px-4 fw-bold">Xem ngay</a>
            </div>
        </div>
        <div class="col-md-5 text-center">
            <a href="/unity" target="_blank" class="d-inline-block img-hover mt-4 mt-md-0">
                <img src="~/Unity/Unity.png" class="img-fluid rounded-3 shadow-lg border" style="max-width: 300px;" />
            </a>
        </div>
    </div>
</div>